<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Action REGULE (placée AVANT utilisation dans le form) -->
    <record id="action_regule_wizard" model="ir.actions.act_window">
        <field name="name">Veuillez choisir la référence de l’écriture à régulariser</field>
        <field name="res_model">regule.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="action_cloturer_balance_wizard" model="ir.actions.act_window">
        <field name="name">Êtes-vous sûr de vouloir clôturer le journal ?</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">cloturer.balance.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="view_cloturer_balance_wizard_form" model="ir.ui.view">
        <field name="name">cloturer.balance.wizard.form</field>
        <field name="model">cloturer.balance.wizard</field>
        <field name="arch" type="xml">
            <form string="Clôture du journal">
                <sheet>
                    <footer>
                        <button string="Confirmer" type="object" name="action_confirm_cloture" class="btn-primary"/>
                        <button string="Annuler" special="cancel" class="btn-secondary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>


    <record id="view_account_daily_balance_form" model="ir.ui.view">
        <field name="name">account.daily.balance.form</field>
        <field name="model">account.daily.balance</field>
        <field name="arch" type="xml">
            <form string="Totaux Journaliers">
                <header>
                    <field name="etat" invisible="1"/>
                    <field name="show_advance_payment_button" invisible="1"/>
                    <button name="action_update_totals_wizard"
                            type="object"
                            string="AJOUT RECETTE DU JOUR"
                            class="btn-primary"/>
                    <button name="action_open_advance_payment_wizard"
                            type="object"
                            string="AVANCE SUR PAYMENT"
                            class="btn-primary"
                            invisible="etat == 'cloturer' or not show_advance_payment_button"/>
                    <button name="action_update_totals"
                            type="object"
                            string="UPDATE"
                            class="btn-success"/>

                    <button name="%(action_regule_wizard)d"
                            type="action"
                            string="REGULE"
                            class="btn-danger oe_highlight"
                            context="{'default_balance_id': active_id}"/>
                    <button name="%(action_cloturer_balance_wizard)d"
                            type="action"
                            string="CLOTURER"
                            class="btn-warning"
                            context="{'default_balance_id': active_id}"/>

                </header>

                <sheet>
                    <field name="company_currency_id" invisible="1"/>
                    <div class="daily-balance-summary">
                        <div class="daily-balance-summary-item">
                            <strong>Date :</strong>
                            <field name="date" nolabel="1" readonly="1"/>
                        </div>
                        <div class="daily-balance-summary-item">
                            <strong>Company :</strong>
                            <field name="company_id" nolabel="1" readonly="1"/>
                        </div>
                        <div class="daily-balance-summary-item">
                            <strong>Ancien solde :</strong>
                            <field name="ancien_solde" nolabel="1" readonly="1"
                                   widget="monetary"
                                   options="{'currency_field': 'company_currency_id'}"/>
                        </div>
                        <div class="daily-balance-summary-item">
                            <strong>Total Décaissements :</strong>
                            <field name="total_debit" nolabel="1" readonly="1"
                                   widget="monetary"
                                   options="{'currency_field': 'company_currency_id'}"/>
                        </div>
                        <div class="daily-balance-summary-item">
                            <strong>Total Encaissements :</strong>
                            <field name="total_credit" nolabel="1" readonly="1"
                                   widget="monetary"
                                   options="{'currency_field': 'company_currency_id'}"/>
                        </div>
                        <div class="daily-balance-summary-item">
                            <strong>Nouveau solde :</strong>
                            <field name="nouveau_solde" nolabel="1" readonly="1"
                                   widget="monetary"
                                   options="{'currency_field': 'company_currency_id'}"/>
                        </div>
                    </div>

                    <field name="show_lines" invisible="1"/>
                    <field name="show_lines"
                           widget="daily_balance_dashboard"
                           class="daily-balance-dashboard-field"
                           nolabel="1"
                           readonly="1"/>

                    <separator string="Détails du jour"/>

                    <field name="line_ids"
                           nolabel="1"
                           domain="[('balance_id.date', '=', date),('company_id', '=', company_id)]"
                           modifiers='{"invisible": [["show_lines", "=", false]]}'>

                        <tree create="false" edit="false" delete="false" default_order="id asc"
                              decoration-danger="libelle == 'REGULE'"
                              options="{'no_open': True}"> <!--  Ligne REGULE en rouge -->
                            <!-- 🏷 Badge REGULÉ affiché en rouge -->
                            <field name="regule_badge"
                                   widget="badge"
                                   string=""
                                   decoration-danger="regule_badge == 'REGULE'"
                                   width="50"/>

                            <field name="id" string="ID" width="40"/>
                            <field name="categorie" string="Catégorie" width="100"/>
                            <field name="reference"/>
                            <field name="payment_date"/>
                            <field name="journal_id"/>
                            <field name="libelle"/>
                            <field name="payment"/>
                            <field name="debit"/>
                            <field name="credit"/>
                        </tree>
                        <form string="Détails (Lecture seule)" create="false" edit="false">
                            <group>
                                <h3>Lecture seule</h3>
                            </group>
                        </form>
                    </field>

                </sheet>
            </form>
        </field>
    </record>

    <record id="view_account_daily_balance_tree" model="ir.ui.view">
        <field name="name">account.daily.balance.tree</field>
        <field name="model">account.daily.balance</field>
        <field name="arch" type="xml">
            <tree string="Totaux Journaliers">
                <field name="date"/>
                <field name="company_id"/>
                <field name="ancien_solde" widget="monetary" options="{'currency_field': 'company_currency_id'}"
                       class="o_field_number"/>
                <field name="total_debit" widget="monetary" options="{'currency_field': 'company_currency_id'}"
                       class="o_field_number"/>
                <field name="total_credit" widget="monetary" options="{'currency_field': 'company_currency_id'}"
                       class="o_field_number"/>
                <field name="nouveau_solde" widget="monetary" options="{'currency_field': 'company_currency_id'}"
                       class="o_field_number"/>
                <!-- Badge coloré pour l'état -->
                <field name="etat" widget="badge"
                       options="{'badge_success': ['ouvert'], 'badge_danger': ['cloturer']}"/>
            </tree>

        </field>
    </record>

    <record id="view_account_daily_balance_line_dashboard_tree" model="ir.ui.view">
        <field name="name">account.daily.balance.line.dashboard.tree</field>
        <field name="model">account.daily.balance.line</field>
        <field name="arch" type="xml">
            <tree string="Documents d'origine" create="false" edit="false" delete="false">
                <field name="balance_id"/>
                <field name="reference"/>
                <field name="libelle"/>
                <field name="move_id" string="Facture d'origine"/>
                <field name="payment_id" string="Paiement d'origine"/>
                <field name="expense_id" string="Dépense d'origine"/>
                <field name="journal_id"/>
                <field name="payment_date"/>
                <field name="debit"/>
                <field name="credit"/>
            </tree>
        </field>
    </record>


    <!-- Wizard recette -->
    <record id="view_update_totals_wizard_form" model="ir.ui.view">
        <field name="name">update.totals.wizard.form</field>
        <field name="model">update.totals.wizard</field>
        <field name="arch" type="xml">
            <form string="Veuillez entrer la description et la référence de la recette et le montant">
                <field name="balance_id" invisible="1"/>
                <group>
                    <field name="libelle" placeholder="Ex: RECETTE"/>
                    <field name="recette"/>
                </group>
                <footer>
                    <button string="Confirmer" type="object" name="action_confirm" class="btn-primary"/>
                    <button string="Annuler" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open wizard recette -->
    <record id="action_update_totals_wizard" model="ir.actions.act_window">
        <field name="name">Wizard Update Totals</field>
        <field name="res_model">update.totals.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_balance_id': active_id}</field>
    </record>

    <!-- View REGULE Wizard -->
    <record id="view_regule_wizard_form" model="ir.ui.view">
        <field name="name">regule.wizard.form</field>
        <field name="model">regule.wizard</field>
        <field name="arch" type="xml">
            <form string="Réguler la ligne">
                <field name="balance_id" invisible="1"/>
                <field name="company_id" invisible="1"/>
                <group>
                    <field name="reference_id"
                           string="Référence"
                           domain="[('balance_id', '=', balance_id), ('company_id', '=', company_id)]"
                           options="{'no_create': True, 'no_create_edit': True}"/>
                    <field name="montant" readonly="1"/>
                </group>
                <footer>
                    <button string="Confirmer" type="object" name="action_confirm_regule" class="btn-primary"/>
                    <button string="Annuler" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>


    <!-- Initial balance wizard -->
    <record id="view_account_daily_balance_init_wizard" model="ir.ui.view">
        <field name="name">account.daily.balance.init.wizard.form</field>
        <field name="model">account.daily.balance.init.wizard</field>
        <field name="arch" type="xml">
            <form string="Saisir le solde initial">
                <group>
                    <field name="initial_balance"/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Valider" class="btn-primary"/>
                    <button string="Annuler" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_paid_daily_total" model="ir.actions.act_window">
        <field name="name">Journal Espèces</field>
        <field name="res_model">account.daily.balance</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('company_id','in',context.get('allowed_company_ids', []))]</field>
    </record>

    <!-- MENU PRINCIPAL TRESORERIE -->
    <menuitem id="menu_paid_totals_main"
              name="Trésorerie"
              sequence="50"/>

    <!-- MENU SECONDAIRE -->
    <menuitem id="menu_paid_totals_list"
              name="Journaux"
              parent="menu_paid_totals_main"
              sequence="1"/>

    <!-- JOURNAL ESPECES -->
    <menuitem id="menu_cash_journal"
              name="Journal Espèces"
              parent="menu_paid_totals_list"
              action="action_paid_daily_total"
              sequence="1"/>

</odoo>
