<odoo>
    <record id="group_paid_totals_user" model="res.groups">
        <field name="name">Utilisateurs Journaux Trésorerie</field>
        <field name="category_id" ref="base.module_category_accounting"/>
    </record>

    <record id="rule_mobile_money_operator_company" model="ir.rule">
        <field name="name">Journaux de trésorerie : sociétés autorisées</field>
        <field name="model_id" ref="model_mobile_money_operator"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('custom_paid_totals.group_paid_totals_user'))]"/>
    </record>

    <record id="rule_account_daily_balance_mobile_company" model="ir.rule">
        <field name="name">Balances mobiles : sociétés autorisées</field>
        <field name="model_id" ref="model_account_daily_balance_mobile"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('custom_paid_totals.group_paid_totals_user'))]"/>
    </record>

    <record id="rule_account_daily_balance_mobile_line_company" model="ir.rule">
        <field name="name">Lignes mobiles : sociétés autorisées</field>
        <field name="model_id" ref="model_account_daily_balance_mobile_line"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('custom_paid_totals.group_paid_totals_user'))]"/>
    </record>

    <record id="rule_treasury_analysis_report_company" model="ir.rule">
        <field name="name">Analyse trésorerie : sociétés autorisées</field>
        <field name="model_id" ref="model_treasury_analysis_report"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('custom_paid_totals.group_paid_totals_user'))]"/>
    </record>
</odoo>
