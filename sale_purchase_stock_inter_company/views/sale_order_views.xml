<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_reverse_intercompany" model="ir.ui.view">
        <field name="name">sale.order.form.reverse.intercompany</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="intercompany_buyer_company_id" readonly="1"/>
                <field name="intercompany_purchase_id" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
