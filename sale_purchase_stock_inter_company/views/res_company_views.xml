<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_reverse_intercompany" model="ir.ui.view">
        <field name="name">res.company.form.reverse.intercompany</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Reverse Intercompany">
                    <group>
                        <field name="reverse_intercompany_sale_purchase"/>
                        <field name="reverse_intercompany_auto_prepare_receipt"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
