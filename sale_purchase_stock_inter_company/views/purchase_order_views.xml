<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="purchase_order_form_reverse_intercompany" model="ir.ui.view">
        <field name="name">purchase.order.form.reverse.intercompany</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="is_reverse_intercompany_purchase" readonly="1"/>
                <field name="intercompany_sale_id" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
