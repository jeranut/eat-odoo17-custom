<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vendor_unpaid_supplier_report_wizard_form" model="ir.ui.view">
        <field name="name">vendor.unpaid.supplier.report.wizard.form</field>
        <field name="model">vendor.unpaid.supplier.report.wizard</field>
        <field name="arch" type="xml">
            <form string="État des factures impayées">
                <group>
                    <field name="report_scope" invisible="1"/>
                    <field name="partner_id" invisible="1"/>
                    <field name="print_mode" widget="radio"/>
                    <field name="date_from"
                           string="Date de facturation début"
                           invisible="print_mode != 'range'"
                           required="print_mode == 'range'"/>
                    <field name="date_to"
                           string="Date de facturation fin"
                           invisible="print_mode != 'range'"
                           required="print_mode == 'range'"/>
                    <field name="report_date"
                           string="Date de facturation"
                           invisible="print_mode != 'date'"
                           required="print_mode == 'date'"/>
                    <field name="available_partner_ids" invisible="1"/>
                    <field name="partner_ids"
                           string="Fournisseurs"
                           invisible="report_scope != 'supplier'"
                           widget="many2many_tags"
                           options="{'no_create': True, 'no_open': True}"/>
                    <field name="partner_ids"
                           string="Clients"
                           invisible="report_scope != 'customer'"
                           widget="many2many_tags"
                           options="{'no_create': True, 'no_open': True}"/>
                </group>
                <footer>
                    <button name="action_print_pdf" string="Imprimer PDF" type="object" class="btn-primary"/>
                    <button string="Annuler" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_unpaid_vendor_report_wizard" model="ir.actions.act_window">
        <field name="name">État des impayés fournisseurs</field>
        <field name="res_model">vendor.unpaid.supplier.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_vendor_unpaid_supplier_report_wizard_form"/>
        <field name="context">{'active_ids': [], 'active_id': False, 'default_report_scope': 'supplier'}</field>
        <field name="target">new</field>
    </record>

    <record id="action_unpaid_customer_report_wizard" model="ir.actions.act_window">
        <field name="name">État des impayés clients</field>
        <field name="res_model">vendor.unpaid.supplier.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_vendor_unpaid_supplier_report_wizard_form"/>
        <field name="context">{'active_ids': [], 'active_id': False, 'default_report_scope': 'customer'}</field>
        <field name="target">new</field>
    </record>
</odoo>
