<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_in_invoice_bill_tree_inherit_unpaid_supplier_report" model="ir.ui.view">
        <field name="name">account.move.bill.tree.vendor.unpaid</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_in_invoice_bill_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree/header" position="inside">
                <button name="%(action_unpaid_vendor_report_wizard)d"
                        string="État des impayés"
                        type="action"
                        class="btn-primary"
                        display="always"
                        context="{'active_ids': [], 'active_id': False}"/>
            </xpath>
        </field>
    </record>

    <record id="view_out_invoice_tree_inherit_unpaid_customer_report" model="ir.ui.view">
        <field name="name">account.move.customer.invoice.tree.unpaid</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_out_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree/header" position="inside">
                <button name="%(action_unpaid_customer_report_wizard)d"
                        string="État des impayés clients"
                        type="action"
                        class="btn-primary"
                        display="always"
                        context="{'active_ids': [], 'active_id': False, 'default_report_scope': 'customer'}"/>
            </xpath>
        </field>
    </record>
</odoo>
